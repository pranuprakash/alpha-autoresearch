# ── LLM Provider Configuration ──
#
# Option A: Claude Max (no API bill)
#   Install Claude Code: https://claude.ai/code
#   Set model prefix to "claude-cli/" in config.yaml (this is the default).
#   No keys needed — uses your local claude CLI and Max subscription.
#
# Option B: API keys
#   Set model prefix to "anthropic/", "openai/", or "google/" in config.yaml,
#   then provide the matching key below.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Optional Data Provider Keys ──
# Leave blank to use yfinance (free, no key needed).
POLYGON_API_KEY=
FRED_API_KEY=
